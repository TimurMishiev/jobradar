# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev:   postgresql://youruser@localhost:5432/jobradar
# Railway:     set automatically when you add a Postgres plugin
DATABASE_URL="postgresql://youruser@localhost:5432/jobradar"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Dev: your Vite dev server URL
# Production with WEB_DIST_PATH set: not needed (same-origin)
# Production with separate web host: set to that host's origin
WEB_URL=http://localhost:5173

# ─── Static web serving (production only) ─────────────────────────────────────
# Absolute path to built web assets inside the container.
# When set, Fastify serves the React SPA from this path.
# Leave blank in local dev — Vite handles the web.
# Docker value: /app/packages/web/dist
WEB_DIST_PATH=

# ─── AI (optional) ────────────────────────────────────────────────────────────
# App runs without this — scoring, NL search, and agents are disabled.
OPENAI_API_KEY=

# ─── Security (recommended in production) ─────────────────────────────────────
# If set, all API requests must include: x-api-key: <value>
API_KEY=

# ─── Resume storage (optional — falls back to local filesystem if not set) ────
# Create a Cloudflare R2 bucket and generate an API token with R2 permissions.
# Account ID: found on the Cloudflare dashboard → R2 overview page.
# Leave all blank for local dev (files stored in packages/api/uploads/resumes/).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ─── Scheduler overrides (optional) ──────────────────────────────────────────
# Ingestion: default every 4 hours. Briefing: default 7am daily.
INGEST_CRON=
BRIEFING_CRON=
