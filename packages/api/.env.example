DATABASE_URL="postgresql://postgres:password@localhost:5432/jobradar"
PORT=3000
HOST=0.0.0.0
WEB_URL=http://localhost:5173
LOG_LEVEL=info
NODE_ENV=development

# Single-user mode: set this to require API key on all requests.
# Leave blank to allow all requests (fine for local dev).
API_KEY=

# Ingestion schedule (cron syntax). Default: every 4 hours.
# Examples:
#   '0 */2 * * *'   every 2 hours
#   '0 */4 * * *'   every 4 hours (default)
#   '0 8,12,18 * * *' at 8am, noon, and 6pm
INGEST_CRON=

# Added in Phase 4 — leave blank until then
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
