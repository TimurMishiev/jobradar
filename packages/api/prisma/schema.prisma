generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile    UserProfile?
  resumes    Resume[]
  jobActions UserJobAction[]
}

model UserProfile {
  id                 String           @id @default(cuid())
  userId             String           @unique
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetTitles       String[]
  targetSkills       String[]
  preferredCompanies String[]
  targetLocations    String[]
  remotePreference   RemotePreference @default(ANY)
  seniorityPref      String[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

enum RemotePreference {
  REMOTE_ONLY
  HYBRID
  ONSITE
  ANY
}

// ─── Resume ───────────────────────────────────────────────────────────────────

model Resume {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  filename    String
  storagePath String
  mimeType    String
  sizeBytes   Int
  textContent     String?   // extracted plain text, used for scoring
  extractedSkills String[]  // auto-extracted skills via GPT, populated after upload
  isDefault       Boolean   @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scores JobScore[]
}

// ─── Job ──────────────────────────────────────────────────────────────────────

model Job {
  id                    String    @id @default(cuid())
  sourceType            String    // greenhouse | lever | custom
  sourceName            String    // human-readable source label
  externalJobId         String?   // stable ID from the source system
  company               String
  title                 String
  url                   String
  location              String?
  remoteType            String?   // remote | hybrid | onsite | unknown
  descriptionRaw        String?
  descriptionNormalized String?
  postedAt              DateTime?
  fetchedAt             DateTime  @default(now())
  tags                  String[]
  seniorityGuess        String?   // intern | junior | mid | senior | staff | principal | unknown
  employmentType        String?   // full_time | part_time | contract | internship | unknown
  isActive              Boolean   @default(true)
  rawPayload            Json?     // original source payload stored for debugging
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  scores       JobScore[]
  userActions  UserJobAction[]
  scoreHistory ScoreHistory[]

  // Dedup: for structured sources (Greenhouse/Lever), (sourceType, company, externalJobId) is unique.
  // URL-based dedup is handled in ingestion code for sources without stable IDs.
  @@unique([sourceType, company, externalJobId])
  @@index([company])
  @@index([isActive])
  @@index([postedAt])
  @@index([createdAt])
}

// ─── Scoring ──────────────────────────────────────────────────────────────────

model JobScore {
  id             String   @id @default(cuid())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeId       String?
  resume         Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  score          Int      // 0–100
  previousScore  Int?     // score before the most recent rescore — null on first scoring
  fitCategory    String?  // high | medium | low
  explanation    String?
  skillsMatch    Json?    // legacy: { matched: string[], missing: string[], bonus: string[] }
  matchReasons   String[] // v1.1: why this job is a good fit
  missingSignals String[] // v1.1: what the candidate lacks
  summary        String?  // v1.1: 1-2 sentence human-readable summary
  modelUsed      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([jobId, resumeId])
}

// ─── User Job Actions ─────────────────────────────────────────────────────────

model UserJobAction {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  action    JobAction
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, jobId])
  @@index([userId, action])
}

enum JobAction {
  SAVED
  IGNORED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

// ─── Score History ────────────────────────────────────────────────────────────
//
// Lightweight audit trail of score changes per job. Written on every scoreJob call.
// Capped at 10 entries per job (oldest pruned automatically).
//
model ScoreHistory {
  id            String       @id @default(cuid())
  jobId         String
  job           Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId        String
  score         Int
  trigger       ScoreTrigger
  reasonSummary String?
  createdAt     DateTime     @default(now())

  @@index([jobId])
  @@index([jobId, userId])
  @@index([userId, createdAt])
}

enum ScoreTrigger {
  INITIAL
  PROFILE_CHANGE
  RESUME_CHANGE
  MANUAL
}

// ─── Agent Insights ───────────────────────────────────────────────────────────
//
// Persisted outputs from reasoning modules. Each agent writes one record per run.
// The frontend reads the latest record for each type.
//
// type values: daily_briefing | gap_analysis | company_signals
//
model AgentInsight {
  id          String   @id @default(cuid())
  type        String
  generatedAt DateTime @default(now())
  payload     Json

  @@index([type])
  @@index([generatedAt])
}
