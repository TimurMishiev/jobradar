# The Vite dev server proxies /api to localhost:3000 automatically (see vite.config.ts).
# This variable is only needed when running the built frontend against a deployed API.
VITE_API_URL=http://localhost:3000

# ⚠️  Do NOT set an API key here.
# VITE_* variables are embedded in the browser bundle as plain text.
# The API_KEY (if you set one in packages/api/.env) is a backend-only secret.
# In single-user local mode, leave API_KEY blank and this file needs no changes.
